# Local MongoDB Compass example (database name: taskdb)
MONGO_URI=mongodb://127.0.0.1:27017/taskdb
PORT=5000
JWT_SECRET=your_strong_jwt_secret_here

# Production CORS — your deployed frontend URL(s), no trailing slash
FRONTEND_URL=https://your-app.netlify.app
# Optional extra origins (comma-separated): Vercel preview, custom domain
# CORS_ORIGINS=https://your-app.vercel.app,https://library.example.com

CLOUD_NAME=your_cloudinary_cloud_name
CLOUD_API_KEY=your_cloudinary_api_key
CLOUD_API_SECRET=your_cloudinary_api_secret
# --- Email (Resend — recommended for deploy) ---
# Sign up: https://resend.com → API Keys → create key
RESEND_API_KEY=re_xxxxxxxxxxxx
# Free test sender (only delivers to your Resend account email until domain verified):
RESEND_FROM=e-GranthaAlaya <onboarding@resend.dev>
# After verifying a domain at resend.com/domains:
# RESEND_FROM=e-GranthaAlaya <noreply@yourdomain.com>

# --- Email fallback (Gmail SMTP — optional if not using Resend) ---
EMAIL_USER=
EMAIL_PASS=
EMAIL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
FINE_RATE_PER_DAY=10
